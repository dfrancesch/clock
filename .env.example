# =============================================================================
# APPLICATION
# =============================================================================
# APP_NAME: Nombre de la aplicación (notificaciones, títulos).
# APP_ENV: Entorno (local, production, staging). Afecta caché y mensajes.
# APP_KEY: Clave de cifrado. Generar con: php artisan key:generate
# APP_DEBUG: true muestra errores detallados; usar false en producción.
# APP_URL: URL base pública (usada en emails, enlaces, storage, Sanctum).
# ASSET_URL: URL base para assets si se sirven desde CDN o otro dominio (opcional).
# =============================================================================

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL=

# =============================================================================
# LOGGING
# =============================================================================
# LOG_CHANNEL: Canal por defecto (stack, single, daily, slack, stderr, null).
# LOG_DEPRECATIONS_CHANNEL: Canal para avisos de deprecación (null para ignorar).
# LOG_LEVEL: Nivel mínimo (debug, info, notice, warning, error, critical, alert, emergency).
# LOG_FILENAME: Nombre del archivo de log cuando el canal usa archivo (ej. laravel).
# =============================================================================

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_FILENAME=laravel

# =============================================================================
# DATABASE
# =============================================================================
# DB_CONNECTION: Driver (mysql, pgsql, sqlite, sqlsrv).
# DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD: Conexión MySQL/Postgres.
# DB_SOCKET: Socket Unix para MySQL (opcional; si se usa, puede ignorarse host/port).
# DATABASE_URL: URL completa de conexión (opcional; sustituye a las variables anteriores).
# =============================================================================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
# DB_SOCKET=
# DATABASE_URL=

# =============================================================================
# CACHE, QUEUE, SESSION, FILESYSTEM
# =============================================================================
# CACHE_DRIVER: file, database, redis, memcached, dynamodb, array.
# QUEUE_CONNECTION: sync (inmediato), database, redis, sqs, etc.
# SESSION_DRIVER: file, cookie, database, redis, memcached, array.
# SESSION_LIFETIME: Minutos hasta expiración de la sesión.
# FILESYSTEM_DRIVER: Disco por defecto (local, public, s3). local = storage/app.
# =============================================================================

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# =============================================================================
# MEMCACHED (si CACHE_DRIVER o SESSION_DRIVER = memcached)
# =============================================================================

MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
# MEMCACHED_USERNAME=
# MEMCACHED_PASSWORD=
# MEMCACHED_PERSISTENT_ID=

# =============================================================================
# REDIS (si CACHE_DRIVER, SESSION_DRIVER o QUEUE_CONNECTION = redis)
# =============================================================================
# REDIS_URL: URL completa (opcional). Si se define, puede usarse en lugar de host/port/password.
# REDIS_CLIENT: phpredis o predis.
# =============================================================================

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_URL=
# REDIS_CLIENT=phpredis
# REDIS_DB=0
# REDIS_CACHE_DB=1

# =============================================================================
# MAIL
# =============================================================================
# MAIL_MAILER: smtp, sendmail, mailgun, ses, postmark, log, array, failover.
# MAIL_HOST, MAIL_PORT, MAIL_USERNAME, MAIL_PASSWORD, MAIL_ENCRYPTION: Para SMTP.
# MAIL_FROM_ADDRESS / MAIL_FROM_NAME: Remitente por defecto.
# MAIL_SENDMAIL_PATH: Ruta de sendmail (solo si MAIL_MAILER=sendmail).
# MAIL_LOG_CHANNEL: Canal de log cuando MAIL_MAILER=log (opcional).
# =============================================================================

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_SENDMAIL_PATH=/usr/sbin/sendmail -t -i
# MAIL_LOG_CHANNEL=

# =============================================================================
# AWS / S3 (si FILESYSTEM_DRIVER=s3 o uso de SES/SQS)
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# PUSHER (si BROADCAST_DRIVER=pusher)
# =============================================================================

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# Variables para Mix/Vite (build frontend)
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# =============================================================================
# SANCTUM (autenticación API / SPA)
# =============================================================================
# SANCTUM_STATEFUL_DOMAINS: Dominios que reciben cookies de sesión (separados por coma).
# Por defecto se añade el host de APP_URL. Ej.: localhost,127.0.0.1,tudominio.com
# =============================================================================

# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# =============================================================================
# SESSION (opcional)
# =============================================================================
# SESSION_DOMAIN: Dominio de la cookie (ej. .tudominio.com).
# SESSION_SECURE_COOKIE: true para enviar cookie solo por HTTPS (recomendado en producción).
# SESSION_CONNECTION: Conexión Redis/DB para sesión si no usa la por defecto.
# =============================================================================

# SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=
# SESSION_CONNECTION=null
# SESSION_STORE=null

# =============================================================================
# OTRAS (opcional)
# =============================================================================
# BCRYPT_ROUNDS: Coste del hash de contraseñas (default 10).
# QUEUE_FAILED_DRIVER: Driver para tabla de jobs fallidos (ej. database-uuids).
# =============================================================================

# BCRYPT_ROUNDS=10
# QUEUE_FAILED_DRIVER=database-uuids
